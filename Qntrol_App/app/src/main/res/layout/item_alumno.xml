<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_gradient"
    android:padding="20dp">

    <ImageView
        android:id="@+id/ivUserIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="Icono de usuario"
        android:src="@drawable/ic_user"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMainName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="@font/inter"
        android:text="Nombre Alumno"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/ivUserIcon"
        app:layout_constraintEnd_toStartOf="@+id/cb1"
        app:layout_constraintStart_toEndOf="@+id/ivUserIcon"
        app:layout_constraintTop_toTopOf="@+id/ivUserIcon" />

    <ImageView
        android:id="@+id/ivArrow1"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="12dp"
        android:contentDescription="Flecha indicadora"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintStart_toStartOf="@+id/ivUserIcon"
        app:layout_constraintTop_toBottomOf="@+id/tvMainName" />

    <ImageView
        android:id="@+id/ivArrow"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="26dp"
        android:contentDescription="Flecha indicadora"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivArrow1" />

    <TextView
        android:id="@+id/tvSubName1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/inter"
        android:text="Invitado 1"
        android:textColor="@android:color/white"
        app:layout_constraintEnd_toStartOf="@+id/cb1"
        app:layout_constraintStart_toEndOf="@+id/ivArrow1"
        app:layout_constraintTop_toTopOf="@+id/ivArrow1" />

    <TextView
        android:id="@+id/tvSubName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="26dp"
        android:fontFamily="@font/inter"
        android:text="Invitado 2"
        android:textColor="@android:color/white"
        app:layout_constraintEnd_toStartOf="@+id/cb"
        app:layout_constraintStart_toEndOf="@+id/ivArrow"
        app:layout_constraintTop_toBottomOf="@+id/ivArrow1" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="14/02/2026 - 12:27h"
        android:textColor="#B0B0B0"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@+id/tvSubName1"
        app:layout_constraintTop_toBottomOf="@+id/tvSubName1" />

    <TextView
        android:id="@+id/tvTime2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter"
        android:text="14/02/2026 - 12:27h"
        android:textColor="#B0B0B0"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@+id/tvSubName"
        app:layout_constraintTop_toBottomOf="@+id/tvSubName" />

    <CheckBox
        android:id="@+id/cb1"
        android:layout_width="21dp"
        android:layout_height="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/custom_checkbox"
        android:button="@null"
        android:clickable="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <CheckBox
        android:id="@+id/cb"
        android:layout_width="21dp"
        android:layout_height="20dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/custom_checkbox"
        android:button="@null"
        android:clickable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cb1"
        app:layout_constraintVertical_bias="0.3" />

</androidx.constraintlayout.widget.ConstraintLayout>