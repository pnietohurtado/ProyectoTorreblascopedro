<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Header with Back Button and Aforo -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerScanner"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/boton"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackScanner"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Volver"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvAforoQr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:text="Aforo: --/--"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Marco encima de la cámara -->
    <View
        android:id="@+id/frameOverlay"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/qr_frame"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    
    <!-- Overlay de Feedback (Verde/Rojo) -->
    <RelativeLayout
        android:id="@+id/overlayFeedback"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/cardFeedback"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="@drawable/bg_rounded_feedback">

            <ImageView
                android:id="@+id/ivFeedbackIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvFeedbackMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="MENSAJE"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="@font/inter_bold" />
        </LinearLayout>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>