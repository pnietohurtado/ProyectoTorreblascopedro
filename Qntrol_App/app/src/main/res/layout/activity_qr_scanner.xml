<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Header with Back Button and Aforo -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerScanner"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/boton"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackScanner"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back_content_description"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvAforoQr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:text="@string/capacity_placeholder"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Marco encima de la cámara -->
    <View
        android:id="@+id/frameOverlay"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/qr_frame"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    
    <!-- Overlay de Feedback (Verde/Rojo) -->
    <RelativeLayout
        android:id="@+id/overlayFeedback"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/cardFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clipToOutline="true"
            android:background="@drawable/bg_feedback_card">

            <View
                android:id="@+id/viewFeedbackAccent"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="#43A047" />

            <ImageView
                android:id="@+id/ivFeedbackIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_feedback_icon_circle"
                android:padding="16dp" />

            <TextView
                android:id="@+id/tvFeedbackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:gravity="center"
                android:text="@string/feedback_access_allowed"
                android:textColor="#2B2738"
                android:textSize="21sp"
                android:fontFamily="@font/inter_bold" />

            <TextView
                android:id="@+id/tvFeedbackDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/feedback_access_allowed_detail"
                android:textColor="#756B82"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium" />

            <TextView
                android:id="@+id/tvFeedbackSeatInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_feedback_seat_chip"
                android:gravity="center"
                android:minHeight="36dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:textColor="#2B2738"
                android:textSize="15sp"
                android:fontFamily="@font/inter_bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvFeedbackSectionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_feedback_seat_chip"
                android:gravity="center"
                android:minHeight="34dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textColor="#2B2738"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvFeedbackAutoDismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:text="@string/feedback_auto_dismiss"
                android:textColor="#8A7E98"
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCerrarFeedback"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:text="@string/btn_close"
                android:textColor="@color/white"
                app:backgroundTint="@color/boton"
                android:fontFamily="@font/inter_bold"
                app:cornerRadius="12dp"
                android:textAllCaps="false"
                android:textSize="16sp" />
        </LinearLayout>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
