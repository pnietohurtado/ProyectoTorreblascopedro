<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Non-rounded background with gradient -->
    <item>
        <shape android:shape="rectangle">
            <!-- No corners = sharp edges -->
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/card_gradient_start"
                android:centerColor="@color/card_gradient_center"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Content surface (simpler for header) -->
    <item
        android:top="2dp"
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_surface_color" />
        </shape>
    </item>

</layer-list>
